# NEVER commit a real .env. Fill these in Desktop.

# --- Runtime mode (mock|live). Default is mock everywhere if unset. ---
# Global switch:
TQA_MODE=mock
# Per-adapter overrides (win over TQA_MODE):
# TQA_CHAIN_MODE=mock
# TQA_LLM_MODE=mock
# TQA_PROVENANCE_MODE=mock
# TQA_EVENTSTORE_MODE=mock
# TQA_ORACLE_MODE=mock

# --- Live config (only needed when the matching adapter is live) ---
MANTLE_RPC_URL=
MANTLE_CHAIN_ID=
MANTLE_EXPLORER_API=
MANTLE_EXPLORER_KEY=
DEPLOYER_PRIVATE_KEY=
LLM_API_KEY=
IPFS_API_URL=
IPFS_GATEWAY_URL=
SQLITE_DB_PATH=
